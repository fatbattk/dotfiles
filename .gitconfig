[alias]
  # Amend the currently staged files to the latest commit
  amend = commit --amend --reuse-message=HEAD

  # Append any staged files onto the most recent commit.
  commend = commit --amend --no-edit

  # Custom log formats
  ll = !git --no-pager log --graph --all --decorate --pretty=format:'%C(auto)%h%d  %ad %C(red bold)(%ar%C(red bold))%Creset  %Creset%C(magenta)%an %Creset<%ae>  %C(white bold)%<(80,trunc)%s' --date=iso
  l = !git log -n 25 --graph --pretty=format:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(blue bold)<%an>%Creset'

  # Show verbose output about tags, branches or remotes
  tags = tag -l
  branches = branch -av
  remotes = remote -v

  # Remove branches that have already been merged with main. Has issues with graphite.
  # a.k.a. ‘delete merged’
  dm = "!git branch --merged | grep -v '\\*' | xargs -n 1 git branch -d"

  # Forcepush, but fail if the remote has been updated since you last pulled.
  # Prevents clobbering other people's commits on the same branch unless you really, really want to.
  forcepush = push --force-with-lease
  please = push --force-with-lease --force-if-includes

  # We wanna grab those pesky un-added files!
  stash-all = stash push --include-untracked

  # reset
  unstage = reset HEAD              # remove files from index (tracking)
  uncommit = reset --soft HEAD^     # go back before last commit, with files in uncommitted state

[apply]
  # detect whitespace errors when applying a patch
  whitespace = warn

[branch]
  # Sort by recent branches vs default alphabetical.
  sort = -committerdate

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red
  new = green

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[core]
  # Default editor for commit messages and other inputs
  # Even when EDITOR is set to something else
  editor = vim

  # Make `git rebase` safer on OS X
  # More info: <http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/>
  trustctime = false

  # Prevent showing files whose names contain non-ASCII symbols as unversioned.
  # http://michael-kuehnel.de/git/2014/11/21/git-mac-osx-and-german-umlaute.html
  precomposeunicode = false

  # Enable the filesystem cache (for git bash | windows)
  fscache = true
  # use OS-native line endings
  eol = native
  # convert CRLF to LF on commit, leave LF on checkout
  autocrlf = input
  # warn on irreversible CRLF conversion
  safecrlf = true
  # case-sensitive filenames (avoids silent renames)
  ignorecase = false
  # global gitignore for OS/editor junk
  excludesfile = ~/.gitignore_global

[diff]
  # detect copies in addition to renames
  renames = copies
  # better diffs for code with moved blocks
  algorithm = patience

[init]
  # default branch name.
  defaultBranch = main

[pull]
  # no surprise merge commits, forces explicit rebase decision
  ff = only

[push]
  autoSetupRemote = true

[rerere]
  enabled = true

[user]
  name = FatBat

[github]
  username = fatbattk

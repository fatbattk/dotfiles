ME="$(whoami)"
readonly ME

# (start with a space to be ignored in history)
alias sudo='sudo '  # enable simple aliases to be sudo'ed.
alias _='sudo'
alias grep='grep --color=always'
alias fgrep='fgrep --color=always'
alias cd..=' cd ..'
alias path="echo -e ${PATH//:/\\n}" # print each PATH entry on a separate line.
alias mkdir='mkdir -p'  # always create parent-dirs, if needed.
if [[ "$(uname)" == "Linux" ]]; then
  alias chown='chown --preserve-root'
  alias chmod='chmod --preserve-root'
  alias chgrp='chgrp --preserve-root'
fi

# config shortcuts.
alias aliasconfig='vim ~/.aliases'
alias sshconfig='vim /etc/ssh/sshd_config'
alias zshconfig='vim ~/.zshrc'
alias vimrc='vim ~/.vimrc'
alias ghosttyconfig='ghostty +edit-config'

# quick reload.
alias reload_zsh_profile='source ~/.zshrc'

# process stuffs.
alias pgr='ps aux|grep '
alias psg='pgr'

alias mygrep="fgrep -Irn --exclude-dir={cache,vendor,min,log} --exclude={'*.svg','*.min.js','*.lock'}"
alias tbc="mygrep 'TBC' *"
alias todo="mygrep 'TODO' *"
alias changed="cvs -Q status -l | grep -i 'locally'"
alias tmuxs="tmux -S /tmp/tmux-sess new -s sess-0"
alias find1="find . -iname "
alias findd='find . -type d -iname '
alias findf='find . -type f -iname '
alias finddr='find / -type d -iname '
alias findfr='find / -type f -iname '
alias dupes='find -not -empty -type f -printf "%s\n" | sort -rn | uniq -d | xargs -I{} -n1 find -type f -size {}c -print0 | xargs -0 md5sum | sort | uniq -w32 --all-repeated=separate'	# number of duplicate files. compare size, then md5.

alias lsnewestphp='ls -lt  **/*.php(.om[1,20])'	# list 20 newest php files anywhere in directory hierarchy.
alias lsd="ll -Ad */"		# list directories.
alias ls0='ls *(.L0)'		# list empty files in current dir.
alias ls0d='ls -ld **/*(/^F)'	# list empty subdirs recursively.
alias dirsize='du -skh *(/)'	# list directory sizes.
alias freespace='df -hl'	# show filesystem free space.
alias dfree='freespace'
alias countr='ls -1|wc -l'	# number of files in dir + subdir.

alias curld='curl -O '		# curl download remote name.

# git overwrites.
alias gb='git branch -vv'
alias gbv='gb'
alias gwtl='git worktree list'
gwtaa() {
  # $1=repo branch name.
  if [ -d "../$1" ]; then
    echo "❌ Error: Directory ../$1 already exists"
    return 1
  fi
  git worktree add "../$1" "$1" && cd "../$1" || {
    echo "❌ Failed to create worktree for $1"
    return 1
  }
}
gwtpr() {
  # $1=pr number; $2=remote name.
  local pr="$1"
  local remote="${2:-origin}"
  local branch=$(gh pr view "$pr" --json headRefName -q .headRefName 2>/dev/null)
  git fetch "$remote" "$branch" || {
    echo "❌ Error: Failed to fetch branch $branch from $remote"
    return 1
  }
  gwtaa "$branch" && echo "✅ Successfully made new worktree for PR #$pr: $branch"
}
clean-local-branches() {
  local main_branch="main"
  git rev-parse --verify "$main_branch" &>/dev/null || main_branch="master"

  local -A merged_branches
  while IFS= read -r b; do
    [[ -n "$b" ]] && merged_branches[$b]=1
  done < <(git branch --merged "$main_branch" 2>/dev/null | sed 's/^[* ]*//')

  local branches_info
  branches_info=$(git for-each-ref \
    --format='%(refname:short)|%(objectname:short)|%(contents:subject)' \
    refs/heads/ | grep -vE "^($main_branch|master|develop|rc|unstable)\|")

  [[ -z "$branches_info" ]] && { echo "No branches to clean up!"; return 0; }

  local branch_count=$(echo "$branches_info" | wc -l | tr -d ' ')
  echo "Found $branch_count branches to review\n"

  local deleted_count=0 kept_count=0

  while IFS='|' read -r branch hash subject; do
    local merged=""
    [[ -n "${merged_branches[$branch]}" ]] && merged=" ✓merged"

    print -P "Branch: %K{magenta}%F{white}%B $branch %b%f%k$merged"
    echo "$hash $subject"

    echo -n "Delete? [y/N/q]: "
    read -k 1 answer
    echo

    case $answer in
      y|Y)
        git branch -d "$branch" 2>/dev/null && ((deleted_count++)) || {
          echo -n "Force delete? [y/N]: "
          read -k 1 force
          echo
          [[ $force == "y" ]] && git branch -D "$branch" && ((deleted_count++)) || ((kept_count++))
        }
        ;;
      q|Q) break ;;
      *) ((kept_count++)) ;;
    esac
    echo
  done <<< "$branches_info"

  echo "\nDeleted: $deleted_count | Kept: $kept_count"
}

# logs check.
alias logae='_ tail -n 20 /var/log/apache2/error.log'	# show apache error log.
alias logaa='_ tail -n 20 /var/log/apache2/access.log'	# show apache access log.
alias logsql='_ tail -n 20 /var/log/mysql/error.log'	# show mysql error log.
alias version='lsb_release -a'
alias jc='journalctl '
alias sc='systemctl '

# global aliases. http://zzapper.co.uk/zshtips.html
alias -g ND='*(/om[1])'		# newest directory.
alias -g NF='*(.om[1])'		# newest file.
alias -g M='| more'
alias -g L='| less'
alias -g ...='../..'
alias -g ....='../../..'
alias -g .....='../../../..'

# print line from file.
line(){
	# $1=line number, $2=file.
	sed -n "$1{p;q}" $2
}
alias line=line

# mass rename for same name but different extensions.
rename1(){
	# $1=from filename; $2=to filename.
	for i in "$1".*; do mv "$i" "$2.${i##*.}"; done
}
alias rename1=rename1
# mass rename to remove certain word.
rename2(){
	# $1=regex word. current directory only. non-recursive.
	# eg- A_[xxx].zip B_[xxx].zip ==> rename2 '_\[xxx\]'  ==> A.zip B.zip
	for a in *; do mv "$a" "${a/$1}"; done
}
alias rename2=rename2

# remove .Zone-Identifier extension files. https://blog.realhe.ro/how-to-get-rid-of-zone-identifier-files/
removeZID(){
  find "$1" -type f -name "*:Zone.Identifier" -exec rm -f {} \;
}

# alternative to reload_zsh_profile.
.reload() {
  source ~/.zshrc
}

# Only allow unique entries in the PATH variable.
# This function updates PATH by removing duplicates.
add_path() {
  if ! [[ ":$PATH:" == *":$1:"* ]]; then
    export PATH="$1:$PATH"
  fi
}

# Function to check if a command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Create an archive from a file or directory.
# Usage: archive <output>.<ext> <input...>
archive() {
  case $1 in
    *bz2)       bzip2 "${@:2}" ;;
    *.gz)       gzip -c "${@:2}" > $1 ;;
    *.tar)      tar -cvf $1 "${@:2}" ;;
    *.tbz|*.tbz2|*.tar.bz2) tar -jcvf $1 "${@:2}" ;;
    *.tgz|*.tar.gz)         tar -zcvf $1 "${@:2}" ;;
    *.zip|*.ZIP)            zip -r $1 "${@:2}" ;;
    *)          echo "'${@:2}' cannot be archived via archive()" ;;
  esac
}

# Determine size of a file or total size of a directory.
fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    local arg=-sbh
  else
    local arg=-sh
  fi
  if [[ -n "$@" ]]; then
    du $arg -- "$@"
  else
    du $arg .[^.]* *
  fi
}
